<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 30px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        table, th, td {
            border: 1px solid black;
            padding: 10px;
        }
    </style>
</head>
<body>

    <h1>URL SHORTENER</h1>
   <% if (locals.id) { %>
    <p>
        Generated Short URL:
        <a href="/<%= id %>">
            http://localhost:8001/<%= id %>
        </a>
    </p>
<% } %>
    <form method="POST" action="/url">
        <input
            type="text"
            name="url"
            placeholder="https://google.com"
            required
        >
        <button type="submit">
            Generate
        </button>
    </form>

    <br>

    <table>
        <thead>
            <tr>
                <th>Short ID</th>
                <th>Original URL</th>
                <th>Clicks</th>
            </tr>
        </thead>

        <tbody>
            <% urls.forEach((url) => { %>
                <tr>
                    <td>
                        <a href="/<%= url.shortId %>">
                            <%= url.shortId %>
                        </a>
                    </td>

                    <td>
                        <%= url.redirectUrl %>
                    </td>

                    <td>
                        <%= url.visitHistory.length %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

</body>
</html>